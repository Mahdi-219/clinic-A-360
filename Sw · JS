// Service Worker بسيط جداً — هدفه الوحيد تفعيل خاصية "تثبيت التطبيق"
// في المتصفحات (مثل كروم على أندرويد). لا يقوم بأي تخزين مؤقت (caching)
// حتى لا يسبب مشاكل بعرض بيانات قديمة — كل طلب يروح للسيرفر مباشرة كالمعتاد.

self.addEventListener('install', () => {
  self.skipWaiting();
});

self.addEventListener('activate', (event) => {
  event.waitUntil(self.clients.claim());
});

self.addEventListener('fetch', (event) => {
  event.respondWith(fetch(event.request));
});
